# Generated artifacts — collapse in PR diffs, exclude from language stats.
README.md              linguist-generated=true
projects.json          linguist-generated=true
assets/profile/*.svg   linguist-generated=true binary
reports/*.json         linguist-generated=true

# Ensure consistent line endings for generated text.
.gitattributes text eol=lf
.editorconfig text eol=lf
.gitignore text eol=lf
.github/CODEOWNERS text eol=lf
.markdownlint-cli2.yaml text eol=lf
package.json text eol=lf
package-lock.json text eol=lf
*.md    text eol=lf
*.json  text eol=lf
*.yml   text eol=lf
*.yaml  text eol=lf
*.ps1   text eol=lf
*.psd1  text eol=lf
*.txt   text eol=lf
