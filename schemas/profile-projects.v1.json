{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/SysAdminDoc/SysAdminDoc/main/schemas/profile-projects.v1.json",
  "title": "SysAdminDoc profile projects feed",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "generatedAt",
    "source",
    "provenance",
    "publicRepoCount",
    "projectCount",
    "suppressedCount",
    "projects",
    "suppressed"
  ],
  "properties": {
    "schema": {
      "const": "https://raw.githubusercontent.com/SysAdminDoc/SysAdminDoc/main/schemas/profile-projects.v1.json"
    },
    "generatedAt": {
      "type": "string",
      "format": "date-time"
    },
    "source": {
      "type": "string",
      "const": "SysAdminDoc/SysAdminDoc data/profile-catalog.json"
    },
    "provenance": {
      "$ref": "#/$defs/provenance"
    },
    "publicRepoCount": {
      "type": "integer",
      "minimum": 0
    },
    "projectCount": {
      "type": "integer",
      "minimum": 0
    },
    "suppressedCount": {
      "type": "integer",
      "minimum": 0
    },
    "projects": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/project"
      }
    },
    "suppressed": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/suppressedProject"
      }
    }
  },
  "$defs": {
    "nullableString": {
      "type": [
        "string",
        "null"
      ]
    },
    "nullableUri": {
      "type": [
        "string",
        "null"
      ],
      "format": "uri"
    },
    "sha256": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "nullableCommitSha": {
      "type": [
        "string",
        "null"
      ],
      "pattern": "^[a-f0-9]{40}$"
    },
    "repoEnumeration": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "requestedLimit",
        "returnedCount",
        "truncated"
      ],
      "properties": {
        "requestedLimit": {
          "type": "integer",
          "minimum": 0
        },
        "returnedCount": {
          "type": "integer",
          "minimum": 0
        },
        "truncated": {
          "type": "boolean"
        }
      }
    },
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "version",
        "sourceRepository",
        "sourceCommit",
        "catalogSha256",
        "generatorSha256",
        "projectSchemaSha256",
        "metadataSnapshotAt",
        "metadataProvider",
        "repoEnumeration"
      ],
      "properties": {
        "version": {
          "type": "integer",
          "minimum": 1
        },
        "sourceRepository": {
          "type": "string",
          "const": "SysAdminDoc/SysAdminDoc"
        },
        "sourceCommit": {
          "$ref": "#/$defs/nullableCommitSha"
        },
        "catalogSha256": {
          "$ref": "#/$defs/sha256"
        },
        "generatorSha256": {
          "$ref": "#/$defs/sha256"
        },
        "projectSchemaSha256": {
          "$ref": "#/$defs/sha256"
        },
        "metadataSnapshotAt": {
          "type": "string",
          "format": "date-time"
        },
        "metadataProvider": {
          "type": "string",
          "enum": [
            "graphql",
            "rest-fallback"
          ]
        },
        "repoEnumeration": {
          "$ref": "#/$defs/repoEnumeration"
        }
      }
    },
    "primaryAction": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "label",
        "url"
      ],
      "properties": {
        "kind": {
          "type": "string",
          "enum": [
            "install",
            "live",
            "release",
            "repo"
          ]
        },
        "label": {
          "type": "string"
        },
        "url": {
          "type": "string",
          "format": "uri"
        }
      }
    },
    "suppressedProject": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "suppressedId",
        "suppressed",
        "category",
        "reasonCode",
        "publicReason",
        "visibilityClass"
      ],
      "properties": {
        "suppressedId": {
          "type": "string",
          "pattern": "^suppressed-[0-9]{3}$"
        },
        "suppressed": {
          "type": "boolean",
          "const": true
        },
        "category": {
          "type": "string",
          "enum": [
            "android",
            "desktop",
            "extensions",
            "guides",
            "media",
            "misc",
            "powershell",
            "python",
            "security",
            "suppressed",
            "web"
          ]
        },
        "reasonCode": {
          "type": "string",
          "enum": [
            "duplicate-or-superseded",
            "not-visitor-facing",
            "other",
            "placeholder",
            "private-or-sensitive"
          ]
        },
        "publicReason": {
          "type": "string",
          "enum": [
            "Duplicate or superseded project omitted from the public feed.",
            "Private or sensitive project omitted from the public feed.",
            "Placeholder project omitted from the public feed.",
            "Project omitted because it is not visitor-facing.",
            "Project omitted from the public feed."
          ]
        },
        "visibilityClass": {
          "type": "string",
          "enum": [
            "private-or-sensitive",
            "suppressed"
          ]
        }
      }
    },
    "project": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "repo",
        "title",
        "category",
        "includeInReadme",
        "includeInPortfolio",
        "suppressed",
        "suppressionReason",
        "description",
        "forkOf",
        "forkOfUrl",
        "upstreamLicense",
        "repoUrl",
        "liveUrl",
        "installUrl",
        "downloadUrl",
        "downloadKind",
        "primaryAction",
        "hasDownload",
        "hasLiveDemo",
        "hasDirectInstall",
        "branch",
        "entrypoint",
        "installKind",
        "language",
        "stars",
        "latestReleaseTag",
        "latestReleaseUrl",
        "releaseAssetKinds",
        "releaseAssetNames",
        "releaseAssetInspected",
        "pushedAt",
        "topics",
        "featured",
        "featuredRank",
        "currentlyBuilding",
        "notes"
      ],
      "properties": {
        "repo": {
          "type": "string",
          "pattern": "^[A-Za-z0-9._-]+$"
        },
        "title": {
          "type": "string"
        },
        "category": {
          "type": "string",
          "enum": [
            "android",
            "desktop",
            "extensions",
            "guides",
            "media",
            "misc",
            "powershell",
            "python",
            "security",
            "suppressed",
            "web"
          ]
        },
        "includeInReadme": {
          "type": "boolean"
        },
        "includeInPortfolio": {
          "type": "boolean"
        },
        "suppressed": {
          "type": "boolean"
        },
        "suppressionReason": {
          "$ref": "#/$defs/nullableString"
        },
        "description": {
          "type": "string"
        },
        "forkOf": {
          "$ref": "#/$defs/nullableString"
        },
        "forkOfUrl": {
          "$ref": "#/$defs/nullableUri"
        },
        "upstreamLicense": {
          "$ref": "#/$defs/nullableString"
        },
        "repoUrl": {
          "type": "string",
          "format": "uri"
        },
        "liveUrl": {
          "$ref": "#/$defs/nullableUri"
        },
        "installUrl": {
          "$ref": "#/$defs/nullableUri"
        },
        "downloadUrl": {
          "$ref": "#/$defs/nullableUri"
        },
        "downloadKind": {
          "type": [
            "string",
            "null"
          ],
          "enum": [
            "apk",
            "crx",
            "crx-xpi",
            "download",
            "exe",
            "repo",
            "userscript",
            "zip",
            "zip-xpi",
            null
          ]
        },
        "primaryAction": {
          "$ref": "#/$defs/primaryAction"
        },
        "hasDownload": {
          "type": "boolean"
        },
        "hasLiveDemo": {
          "type": "boolean"
        },
        "hasDirectInstall": {
          "type": "boolean"
        },
        "branch": {
          "type": "string"
        },
        "entrypoint": {
          "$ref": "#/$defs/nullableString"
        },
        "installKind": {
          "type": [
            "string",
            "null"
          ],
          "enum": [
            "powershell",
            "python",
            null
          ]
        },
        "language": {
          "$ref": "#/$defs/nullableString"
        },
        "stars": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 0
        },
        "latestReleaseTag": {
          "$ref": "#/$defs/nullableString"
        },
        "latestReleaseUrl": {
          "$ref": "#/$defs/nullableUri"
        },
        "releaseAssetKinds": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "apk",
              "crx",
              "deb",
              "dmg",
              "exe",
              "jar",
              "other",
              "rpm",
              "script",
              "source-archive",
              "userscript",
              "xpi",
              "zip"
            ]
          }
        },
        "releaseAssetNames": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "releaseAssetInspected": {
          "type": "boolean"
        },
        "pushedAt": {
          "type": [
            "string",
            "null"
          ],
          "format": "date-time"
        },
        "topics": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "featured": {
          "type": "boolean"
        },
        "featuredRank": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 0
        },
        "currentlyBuilding": {
          "type": "boolean"
        },
        "notes": {
          "$ref": "#/$defs/nullableString"
        }
      }
    }
  }
}
